{
  "name": "react-span-annotator",
  "version": "0.2.1",
  "description": "React component for annotating text with named entities and relations",
  "private": false,
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/types/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/gellerby/react-span-annotator.git"
  },
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "author": "Hironsan",
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "annotation",
    "NER",
    "named entity recognition",
    "NLP",
    "text annotation",
    "span annotation"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.config.demo.ts",
    "test:unit": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "dependencies": {
    "@flatten-js/interval-tree": "^1.0.14",
    "core-js": "^3.6.5",
    "grapheme-splitter": "^1.0.4",
    "lodash-es": "^4.17.21",
    "react-window": "^1.8.10",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^27.0.0",
    "@types/jsdom": "^16.2.11",
    "@types/lodash": "^4.14.170",
    "@types/lodash-es": "^4.17.5",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-window": "^1.8.0",
    "@types/uuid": "^9.0.2",
    "@typescript-eslint/eslint-plugin": "^4.18.0",
    "@typescript-eslint/parser": "^4.18.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^6.7.2",
    "eslint-plugin-prettier": "^3.3.1",
    "eslint-plugin-react": "^7.33.0",
    "jsdom": "^16.6.0",
    "prettier": "^2.2.1",
    "ts-jest": "^27.0.0",
    "typescript": "~4.1.5",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4"
  },
  "jest": {
    "setupFiles": [
      "jest-canvas-mock"
    ]
  }
}
